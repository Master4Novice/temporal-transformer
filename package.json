{
  "name": "@master4n/temporal-transformer",
  "version": "2.0.1",
  "description": "TypeScript library to convert epoch timestamps (seconds, milliseconds, microseconds, nanoseconds) to human-readable dates, parse date strings to epoch, compute calendar-accurate durations, and handle IANA timezones. Powered by Luxon — small bundle, immutable, no moment.js.",
  "main": "./dist/commonjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    "import": "./dist/esm/index.js",
    "require": "./dist/commonjs/index.cjs",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "build": "npm run clean && rollup --config",
    "test": "jest --testPathIgnorePatterns='/node_modules/' '/test/golden/'",
    "test:golden": "TZ=UTC jest --testPathPattern='test/golden' --testPathIgnorePatterns='/node_modules/'",
    "test:coverage": "jest --coverage --testPathIgnorePatterns='/node_modules/' '/test/golden/'",
    "bench": "npm run build && node bench/bench.mjs",
    "bench:no-build": "node bench/bench.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Master4Novice/temporal-transformer.git"
  },
  "bugs": {
    "url": "https://github.com/Master4Novice/temporal-transformer/issues"
  },
  "homepage": "https://github.com/Master4Novice/temporal-transformer#readme",
  "keywords": [
    "epoch",
    "epoch-converter",
    "timestamp",
    "unix-timestamp",
    "epoch-to-date",
    "date-to-epoch",
    "timezone",
    "timezone-converter",
    "luxon",
    "temporal",
    "transformer",
    "milliseconds",
    "microseconds",
    "nanoseconds",
    "duration",
    "date-utility",
    "typescript",
    "iso-8601",
    "moment-alternative",
    "immutable-date"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "dwivna",
  "license": "MIT",
  "dependencies": {
    "luxon": "^3.5.0"
  },
  "publishConfig": {
    "directory": "dist",
    "access": "public"
  },
  "contributors": [
    {
      "name": "dwivna"
    }
  ],
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.0.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.4.1",
    "ts-jest": "^29.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "gitHead": "4efbfe6b5967b5aed3aae79794c4da3d67ecf118"
}
